# Optional (default: https://www.cgv.co.kr/ticket/)
CGV_URL=https://www.cgv.co.kr/ticket/

# Required
CGV_MOVIE_NAME=영화 제목
CGV_THEATER_NAME=강남
CGV_DATE=2026-03-20
TELEGRAM_BOT_TOKEN=123456789:example_token
TELEGRAM_CHAT_ID=123456789

# Optional (default: empty string)
CGV_FORMAT=IMAX

# Optional
# POLL_INTERVAL_SECONDS must be a positive integer.
POLL_INTERVAL_SECONDS=60
STATE_FILE=watcher_state.json

# Supported aliases for compatibility:
# 영화제목 -> CGV_MOVIE_NAME
# BOT_TOKEN -> TELEGRAM_BOT_TOKEN
# CHAT_ID -> TELEGRAM_CHAT_ID
CGV_URL=https://www.cgv.co.kr/ticket/
CGV_MOVIE_NAME=영화 제목
CGV_THEATER_NAME=강남
CGV_DATE=2026-03-20
CGV_FORMAT=IMAX

TELEGRAM_BOT_TOKEN=123456789:example_token
TELEGRAM_CHAT_ID=123456789

POLL_INTERVAL_SECONDS=60
STATE_FILE=watcher_state.json
