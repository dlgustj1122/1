# Optional (default: https://cgv.co.kr/cnm/movieBook)
CGV_URL=https://cgv.co.kr/cnm/movieBook

# Required monitor target
CGV_MOVIE_NAME=프로젝트 헤일메리
CGV_THEATER_NAME=용산아이파크몰
CGV_DATE=2026-03-29
CGV_FORMAT=IMAX

# Required Telegram settings
# Use your own real token/chat id in local .env (do not commit secrets)
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_token
TELEGRAM_CHAT_ID=123456789

# Optional
# POLL_INTERVAL_SECONDS must be a positive integer.
POLL_INTERVAL_SECONDS=60
STATE_FILE=watcher_state.json

# Supported aliases for compatibility:
# 영화제목 -> CGV_MOVIE_NAME
# BOT_TOKEN -> TELEGRAM_BOT_TOKEN
# CHAT_ID -> TELEGRAM_CHAT_ID
